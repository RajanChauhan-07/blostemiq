# ─── BlostemIQ Local Dev Environment ─────────────────────
# Copy to .env in each service directory
# DO NOT COMMIT REAL SECRETS

# ─── Shared ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── PostgreSQL ──────────────────────────────────────────
DATABASE_URL=postgresql://blostemiq:blostemiq_dev@localhost:5432/blostemiq

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Kafka ───────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── AWS (LocalStack) ────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
LOCALSTACK_ENDPOINT=http://localhost:4566
ENVIRONMENT=dev

# ─── Auth Service (port 3001) ────────────────────────────
PORT=3001
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder

# ─── Partner Service (port 3002) ─────────────────────────
# PORT=3002
# ALLOWED_ORIGINS=http://localhost:3000

# ─── Notification Service (port 3004) ────────────────────
# PORT=3004
# JWT_SECRET=blostemiq_dev_secret

# ─── Frontend (port 3000) ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=http://localhost:3004
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=blostemiq_dev_secret_change_in_prod
