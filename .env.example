# ─── BlostemIQ Local Dev Environment ─────────────────────
# Copy to .env in each service directory
# DO NOT COMMIT REAL SECRETS

# ─── Shared ──────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info

# ─── PostgreSQL ──────────────────────────────────────────
DATABASE_URL=postgresql://blostemiq:blostemiq_dev_2026@localhost:5432/blostemiq

# ─── Redis ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Kafka ───────────────────────────────────────────────
KAFKA_BROKERS=localhost:9092

# ─── AWS (LocalStack) ────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
LOCALSTACK_ENDPOINT=http://localhost:4566
ENVIRONMENT=dev

# ─── Auth Service (port 3001) ────────────────────────────
PORT=3001
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_EXPIRES_IN=7d
GOOGLE_CLIENT_ID=placeholder
GOOGLE_CLIENT_SECRET=placeholder
JWT_SECRET=replace-with-a-long-random-secret

# ─── Partner Service (port 3002) ─────────────────────────
# PORT=3002
# ALLOWED_ORIGINS=http://localhost:3000

# ─── Notification Service (port 3004) ────────────────────
# PORT=3004

# ─── Frontend (port 3000) ────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=http://localhost:3004
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=blostemiq_dev_secret_change_in_prod

# ─── Outreach Service (port 8003) ────────────────────────
GROQ_API_KEY=placeholder
ELEVENLABS_API_KEY=placeholder
SMTP_HOST=email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_USERNAME=placeholder
SMTP_PASSWORD=placeholder
SMTP_USE_TLS=true
SMTP_FROM_EMAIL=hello@example.com
SMTP_FROM_NAME=BlostemIQ

# ─── Billing Service (port 3005) ─────────────────────────
STRIPE_SECRET_KEY=placeholder
STRIPE_WEBHOOK_SECRET=placeholder
STRIPE_PRICE_GROWTH=price_growth_placeholder
STRIPE_PRICE_ENTERPRISE=price_enterprise_placeholder
BILLING_SUCCESS_URL=http://localhost:3000/dashboard/settings
BILLING_CANCEL_URL=http://localhost:3000/dashboard/settings

# ─── Retention Policy ────────────────────────────────────
RETENTION_AUDIT_DAYS=365
RETENTION_BILLING_DAYS=730
RETENTION_OUTREACH_DAYS=365
RETENTION_REFRESH_TOKEN_DAYS=30
RETENTION_PARTNER_EVENTS_DAYS=730
